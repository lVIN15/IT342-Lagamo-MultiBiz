<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="400dp"
    android:height="80dp"
    android:viewportWidth="400"
    android:viewportHeight="80">
    
    <!-- Deep purple background layer -->
    <path
        android:fillColor="#4A148C"
        android:pathData="M 0,0 L 400,0 L 400,80 L 0,80 Z" />
        
    <!-- Light purple layered wave -->
    <path
        android:fillColor="#7B1FA2"
        android:pathData="M 0,40 Q 100,80 200,40 T 400,40 L 400,80 L 0,80 Z" />

    <!-- Lighter purple top overlapping wave -->
    <path
        android:fillColor="#9C27B0"
        android:pathData="M 0,60 Q 120,20 250,50 T 400,20 L 400,80 L 0,80 Z" />
</vector>
